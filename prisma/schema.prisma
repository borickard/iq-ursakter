// Prisma schema för Ursäkten (POC).
//
// Postgres används så att appen fungerar på serverless-hosting (t.ex. Vercel),
// där filsystemet inte är persistent och SQLite inte håller mellan anrop.
// Använd en hostad Postgres (Neon/Supabase) – samma DATABASE_URL fungerar både
// lokalt och i produktion.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// En ursäkt. Mottagarnummer lagras ALDRIG här – se README/brief avsnitt 7–8.
model Excuse {
  id        String   @id @default(cuid())
  text      String
  // "seed"  = del av den kurerade startlistan
  // "user"  = inskickad av en användare (Fas 2)
  source    String   @default("seed")
  // "approved" | "pending" | "rejected"
  // Endast "approved" visas/skickas. Förbereder Fas 2:s modereringskö.
  status    String   @default("approved")
  // Räknare för hur många gånger ursäkten skickats. Förbereder Fas 2:s
  // popularitetssortering. Visas inte i Fas 1.
  sentCount Int      @default(0)
  createdAt DateTime @default(now())

  @@index([status, source])
}

// En kort inledande konversation som visas FÖRE ursäkten i meddelande-mockupen,
// för att göra tråden trovärdig. Mönstret är inkommande → utgående → inkommande
// (them1 = de, me = du, them2 = de). En slumpas fram varje gång.
model LeadIn {
  id        String   @id @default(cuid())
  them1     String
  me        String
  them2     String
  createdAt DateTime @default(now())
}

// Rate limiting-bucket. Fungerar över flera serverless-instanser (till skillnad
// från in-memory). GDPR: mottagarnumret lagras ALDRIG i klartext – nyckeln för
// nummer-buckets är en saltad HASH. Utgångna buckets städas bort löpande, så
// hashen "auto-raderas" efter rate limit-fönstret (brief avsnitt 7–8).
model RateBucket {
  key     String   @id // "ip:<ip>", "num:<hash>" eller "global:<YYYY-MM-DD>"
  count   Int      @default(0)
  resetAt DateTime

  @@index([resetAt])
}
