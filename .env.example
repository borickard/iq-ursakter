# ───────────────────────────────────────────────────────────────────────────
# Ursäkten – exempel på miljövariabler.
# Kopiera den här filen till .env.local och fyll i värdena.
# .env.local checkas ALDRIG in (se .gitignore). Hemligheter stannar på servern.
# ───────────────────────────────────────────────────────────────────────────

# --- Databas ---------------------------------------------------------------
# SQLite för POC (lokalt). Vid serverless-hosting utan persistent filsystem
# (t.ex. Vercel): byt till en hostad Postgres (Supabase/Neon) och uppdatera
# provider i prisma/schema.prisma till "postgresql".
DATABASE_URL="file:./dev.db"

# --- SMS-leverantör --------------------------------------------------------
# Vilken leverantör som ska användas: "elks" (46elks) eller "dummy".
# "dummy" skickar inga riktiga SMS och loggar bara till servern – bra under
# utveckling så att ingen SMS-budget bränns.
SMS_PROVIDER="dummy"

# Plattformens FASTA sändningsnummer i E.164-format. Det här numret sparar
# användaren i sina kontakter (via vCard) under valt namn, t.ex. "Älskling".
# OBS: detta är INTE hemligt – det exponeras även som NEXT_PUBLIC nedan så att
# vCard kan genereras i klienten. Håll dem synkade.
SMS_FROM_NUMBER="+46700000000"

# Samma nummer, men exponerat till klienten för vCard-generering.
NEXT_PUBLIC_SMS_FROM_NUMBER="+46700000000"

# --- 46elks (krävs bara om SMS_PROVIDER="elks") ----------------------------
# Hämtas i 46elks dashboard. Lägg ALDRIG dessa i klienten eller i repo.
# Under utveckling: skicka till +4670000000 (46elks dummy-nummer) – gratis och
# skickar inget riktigt SMS.
ELKS_API_USERNAME=""
ELKS_API_PASSWORD=""

# --- Rate limiting / kostnadskontroll --------------------------------------
# Max antal SMS per IP inom fönstret.
RATE_LIMIT_PER_IP="5"
# Max antal SMS per mottagarnummer (via kortlivad hash) inom fönstret.
RATE_LIMIT_PER_NUMBER="3"
# Fönstrets längd i sekunder (t.ex. 3600 = 1 timme).
RATE_LIMIT_WINDOW_SECONDS="3600"
# Globalt tak på antal SMS per dygn (budget-skydd). Sätt 0 för obegränsat.
RATE_LIMIT_GLOBAL_DAILY="500"

# Salt för att hasha mottagarnummer i rate limiting. Numret lagras aldrig i
# klartext; hashen lever bara i minnet och raderas efter fönstret.
RATE_LIMIT_HASH_SALT="byt-ut-mig-till-en-lang-slumpmassig-strang"
